{
  "name": "minitmpl",
  "version": "1.0.0",
  "description": "Minimal pure TypeScript template renderer with loud failures for missing variables. Built for LLM prompt assembly.",
  "keywords": [
    "template",
    "templating",
    "render",
    "llm",
    "prompt",
    "mustache",
    "substitution"
  ],
  "author": "Giovanni Collazo <gcollazo@blimp.io>",
  "license": "MIT",
  "type": "module",
  "main": "./src/render.ts",
  "types": "./src/render.ts",
  "exports": {
    ".": "./src/render.ts"
  },
  "files": [
    "src/render.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "playground:build": "bun build docs/index.html --outdir playground-dist --minify",
    "dev": "bun --hot docs/server.ts"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
